# Pangle ad configuration
# Copy this file to .env and replace the values below with real slot IDs.

# General slot. Used as the fallback slot for reward, carousel, and splash ads.
VITE_PANGLE_SLOT_ID=YOUR_SLOT_ID_HERE

# Optional dedicated carousel slot for the homepage ad card.
VITE_PANGLE_CAROUSEL_SLOT_ID=YOUR_CAROUSEL_SLOT_ID_HERE

# Optional dedicated splash slot for the startup screen ad.
VITE_PANGLE_SPLASH_SLOT_ID=YOUR_SPLASH_SLOT_ID_HERE

# Notes
# 1. Copy env.example to .env in the project root.
# 2. Restart the frontend dev server after changing .env.
# 3. Reward ads use VITE_PANGLE_SLOT_ID first and then fall back to the carousel slot.
# 4. Carousel ads use VITE_PANGLE_CAROUSEL_SLOT_ID first and then fall back to the general slot.
# 5. Splash ads use VITE_PANGLE_SPLASH_SLOT_ID first and then fall back to the general slot.
