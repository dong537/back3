# 穿山甲广告配置示例
# 复制此文件为 . 并填入实际的广告位ID

# 通用广告位ID（用于轮播图广告）
VITE_PANGLE_SLOT_ID=YOUR_SLOT_ID_HERE

# 轮播图广告位ID（如果与通用广告位不同）
VITE_PANGLE_CAROUSEL_SLOT_ID=YOUR_CAROUSEL_SLOT_ID_HERE

# 开屏广告位ID
VITE_PANGLE_SPLASH_SLOT_ID=YOUR_SPLASH_SLOT_ID_HERE

# 使用说明：
# 1. 复制此文件为 .（不要提交 . 到版本控制）
# 2. 替换 YOUR_SLOT_ID_HERE 为实际的广告位ID
# 3. 重启开发服务器使配置生效（npm run dev）
# 4. 在移动端或浏览器移动端模拟模式下查看广告
